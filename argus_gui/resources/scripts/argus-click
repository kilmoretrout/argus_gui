        self.filename, _ = QtWidgets.QFileDialog.getOpenFileName(self, caption = win_title, dir = init, filter = filt)

class SaveFilePopup(QtWidgets.QWidget):
    def __init__(self, win_title, init, filt):
        super().__init__()
        # Show the save file dialog
        options = QtWidgets.QFileDialog.Options()
        # options |= QtWidgets.QFileDialog.DontUseNativeDialog
        self.filename, _ = QtWidgets.QFileDialog.getSaveFileName(self, caption=win_title, dir = init, filter = filt, options=options)

def get_initial_save_directory():
    """
    Get the directory of the first loaded video to use as initial directory for save dialogs.
    Falls back to current working directory if no videos are loaded.
    
    Returns:
        str: Directory path for initial save location
    """
    try:
        # Get first video window
        video_windows = [window for window in pyglet.app.windows if isinstance(window, ClickerWindow)]
        if video_windows and video_windows[0].movie:
            return os.path.dirname(video_windows[0].movie)
    except:
        pass
    # Fallback to current working directory
    return os.getcwd()

