#!/usr/bin/env python
# -*- coding: utf-8 -*-

from __future__ import absolute_import
import yaml
import os
import sys

# Fix sys.path to prevent importing from source tree
# The script is located deep within the argus_gui source tree, and Python adds parent
# directories to sys.path which causes namespace package conflicts
script_dir = os.path.dirname(os.path.abspath(__file__)).lower()

# Remove any paths that would lead to finding the source argus_gui directory
paths_to_remove = []
for p in sys.path[:]:
    abs_p = os.path.abspath(p).lower()
    # Remove if argus_gui appears in this path
    if 'argus_gui' in abs_p:
        paths_to_remove.append(p)
    # Remove if this is a parent directory of our script (part of source tree)
    elif script_dir.startswith(abs_p):
        paths_to_remove.append(p)

for p in paths_to_remove:
    if p in sys.path:
        sys.path.remove(p)

# Now make sure site-packages is first
import site
for sp in site.getsitepackages():
    if sp not in sys.path:
        sys.path.insert(0, sp)
    elif sys.path.index(sp) > 0:
        sys.path.remove(sp)
        sys.path.insert(0, sp)

import cv2

# GPU acceleration settings - MUST be set before pyglet import
# By default, pyglet uses hardware OpenGL which leverages GPU acceleration.
# The old code forced software rendering on Windows, preventing GPU usage even on high-end systems.
# This has been changed to allow hardware acceleration by default.
#
# Users can disable hardware acceleration if they encounter driver issues by setting:
#   Windows: set ARGUS_GPU_ACCELERATION=disable
#   Mac/Linux: export ARGUS_GPU_ACCELERATION=disable
if os.environ.get('ARGUS_GPU_ACCELERATION', '').lower() == 'disable':
    # Only apply software rendering fallback if explicitly requested
    print("GPU acceleration disabled via ARGUS_GPU_ACCELERATION environment variable")
    if sys.platform.startswith('win'):
        # Force software rendering if hardware acceleration is problematic
        os.environ['PYGLET_GL_DISABLE_MULTISAMPLING'] = '1'
        os.environ['PYGLET_GL_FALLBACK'] = '1'
        os.environ['PYGLET_SHADOW_WINDOW'] = '0'
        # Force OpenGL software rendering as fallback
        os.environ['MESA_GL_VERSION_OVERRIDE'] = '3.3'
        # Disable advanced OpenGL features that might not be supported
        os.environ['PYGLET_GL_DISABLE_WGL'] = '1'
else:
    # Default: Use hardware OpenGL (pyglet's default behavior)
    # This works on systems with or without dedicated GPUs:
    # - Dedicated GPU: Uses discrete GPU for best performance
    # - Integrated GPU: Uses integrated graphics (still much faster than software rendering)
    # - No GPU: Pyglet automatically falls back to software rendering
    # NOTE: Pyglet automatically handles GPU selection, no environment variables needed
    pass

