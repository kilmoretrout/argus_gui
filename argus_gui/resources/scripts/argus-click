    def accept(self):
        """Override accept to save the likelihood threshold value and re-filter DLC data if needed"""
        global dlc_likelihood_threshold, dlc_h5_file_paths, data_loaded_from_dlc
        
        # Check if likelihood threshold has changed and we have DLC data loaded
        new_threshold = self.dlc_likelihood_input.value()
        threshold_changed = abs(new_threshold - dlc_likelihood_threshold) > 1e-6  # Use small epsilon for float comparison
        
        # Update the global threshold value
        dlc_likelihood_threshold = new_threshold
        
        # Re-filter DLC data if threshold changed and we have DLC data loaded
        if threshold_changed and data_loaded_from_dlc and dlc_h5_file_paths:
            try:
                import pyglet
                
                # Store manually edited points before re-filtering
                manual_edits = {}
                for window in pyglet.app.windows:
                    if isinstance(window, ClickerWindow):
                        manual_edits[window.actual_camera_number] = {}
                        for track_name, track_data in window.points.items():
                            # Store all current points (both DLC and manual)
                            manual_edits[window.actual_camera_number][track_name] = track_data.copy()
                
                # Re-load DLC data with new threshold
                load_dlc(dlc_h5_file_paths, like=dlc_likelihood_threshold)
                
                # Update all video windows with the newly filtered data while preserving manual edits
                for window in pyglet.app.windows:
                    if isinstance(window, ClickerWindow):
                        # Load new DLC data first
                        window.update_tracks()  # Create track keys
                        window.load_points()    # Load newly filtered data from load_data_global
                        
                        # Restore manual edits by overlaying them on top of DLC data
                        if window.actual_camera_number in manual_edits:
                            for track_name, manual_track_data in manual_edits[window.actual_camera_number].items():
                                if track_name in window.points:
                                    # Get the newly filtered DLC data for comparison
                                    new_dlc_data = window.points[track_name].copy()
                                    
                                    # Find all points that exist in the manual edits (current state before re-filtering)
                                    manual_nonzeros = set(manual_track_data.nonzero()[0])
                                    new_dlc_nonzeros = set(new_dlc_data.nonzero()[0])
                                    
                                    # We need to check what the original DLC data was at this threshold
                                    # by reloading just this window's data temporarily
                                    original_dlc_data = load_data_global[:,
                                        2 * track_list_global.index(track_name) * no_cameras_global + 2 * window.original_index:
                                        2 * track_list_global.index(track_name) * no_cameras_global + 2 * window.original_index + 2]
                                    original_dlc_nonzeros = set(original_dlc_data.nonzero()[0])
                                    
                                    # For each point in manual edits, determine if it's a manual modification
                                    for frame_idx in manual_nonzeros:
                                        manual_point = manual_track_data[frame_idx].toarray()[0]
                                        if manual_point[0] != 0 or manual_point[1] != 0:  # Valid manual point
                                            should_preserve = False
                                            
                                            # Case 1: Point exists in manual but not in original DLC = manually added
                                            if frame_idx not in original_dlc_nonzeros:
                                                should_preserve = True
                                            else:
                                                # Case 2: Point exists in both, check if coordinates are different = manually corrected
                                                original_dlc_point = original_dlc_data[frame_idx].toarray()[0]
                                                # Any difference means it was manually edited (even 1 pixel)
                                                if (abs(manual_point[0] - original_dlc_point[0]) > 0.1 or 
                                                    abs(manual_point[1] - original_dlc_point[1]) > 0.1):
                                                    should_preserve = True
                                            
                                            # Case 3: Check for manual deletions (point was in original DLC but removed manually)
                                            # This is harder to detect, but we can infer it if:
                                            # - Point exists in original DLC (would be in new DLC too if threshold allows)
                                            # - Point exists in new DLC (threshold allows it)  
                                            # - But point doesn't exist in manual edits
                                            # This case is handled by NOT restoring points that were manually deleted
                                            
                                            if should_preserve:
                                                window.points[track_name][frame_idx] = manual_point
                                    
                                    # Handle manual deletions: check for points that exist in new DLC but were removed manually
                                    for frame_idx in new_dlc_nonzeros:
                                        if (frame_idx in original_dlc_nonzeros and  # Point was in original DLC
                                            frame_idx not in manual_nonzeros):     # But was removed manually
                                            # This point was manually deleted, so remove it from the new DLC data
                                            window.points[track_name][frame_idx] = np.array([0., 0.])
                        
                        # Redraw the tracks with preserved manual edits
                        window.clearBatch()
                        window.draw_tracks()
                        window.update_drawings()
                
                print(f"DLC data re-filtered with likelihood threshold: {dlc_likelihood_threshold}")
                print("Manual edits have been preserved where possible.")
                
            except Exception as e:
                QtWidgets.QMessageBox.warning(None,
                    "Error",
                    f"Failed to re-filter DeepLabCut data: {str(e)}"
                )
        
        super().accept()

    # close with Return key
    def keyPressEvent(self, event):
        if event.key() == QtCore.Qt.Key_Return:
            self.accept()

    # popup window for inputting track name
    def newTrack(self):
        track_name_window = newTrackPopup(self)
        if track_name_window.exec() == QtWidgets.QDialog.Accepted:
            new_name = track_name_window.line_edit.text()

        # check to make sure the track name is not empty and does not already exist
        if new_name != '' and new_name not in self.track_list:
            self.track_list.append(new_name)
            self.tracks.addItem(new_name)
            self.tracks.setCurrentText(new_name)

        else:
            QtWidgets.QMessageBox.warning(None,
                "Error",
                "Track names must be unique and non-empty"
            )

    def load_camera(self):
        initial_dir = get_initial_save_directory()
        filename, _ = QtWidgets.QFileDialog.getOpenFileName(self, "Choose camera profile", initial_dir, filter="Text files (*.txt)")
        try:
            if filename:
                load_camera(filename)
                self.cam_entry.setText(filename)
        except:
            QtWidgets.QMessageBox.warning(None,
                "Error",
                "Could not load Camera profile!"
            )

    def load_DLT(self):
        global DLTCoefficients
        global dlt_filename
        initial_dir = get_initial_save_directory()
        filename, _ = QtWidgets.QFileDialog.getOpenFileName(self, "Choose DLT coefficients file", initial_dir, filter="CSV files (*.csv)")

        if filename:
            try:
                DLTCoefficients = np.loadtxt(filename, delimiter=',')
                DLTCoefficients = DLTCoefficients.T
                self.dlt.setText(filename)
                dlt_filename = filename
            except Exception as e:
                QtWidgets.QMessageBox.warning(None,
                    "Error",
                    f"Could not load DLT coefficients! {str(e)}"
                )
            
    def sparse_toggle(self):
        if self.formatbox.currentText() == "Sparse .tsv":
            self.o_sparse = True
            self.o_dlc = False
        elif self.formatbox.currentText() == "Dense .csv":
            self.o_sparse = False
            self.o_dlc = False
        elif self.formatbox.currentText() == "DeepLabCut .h5":
            self.o_sparse = False  # DLC format is treated as non-sparse for legacy compatibility
            self.o_dlc = True

    def color_toggle(self):
        if self.colorbox.currentText() == "RGB color":
            self.rgb = True
        elif self.colorbox.currentText() == "grayscale":
            self.rgb = False

    def save_as(self):
        global global_filename
        initial_dir = get_initial_save_directory()
        filename, _ = QtWidgets.QFileDialog.getSaveFileName(self, "Select location and enter file name prefix", initial_dir)
        if filename != '':
            self.fnam.setText(filename)
            global_filename = filename

    def load_dlc_data(self):
        """
        Load DeepLabCut h5 files for each open video window.
        Prompts user to select one h5 file per open video window.
        """
        import pyglet
        global dlc_h5_file_paths
        
        # Get list of open video windows
        video_windows = [window for window in pyglet.app.windows if isinstance(window, ClickerWindow)]
        
        if not video_windows:
            QtWidgets.QMessageBox.warning(None,
                "Error",
                "No video windows are currently open. Please open video files first."
            )
            return
        
        # Track h5 file paths for each window
        h5_file_paths = []
        
        # Sort windows by camera number for consistent ordering
        video_windows.sort(key=lambda w: w.actual_camera_number)
        
        # Get the directory from the first video to use as initial directory
        initial_dir = ""
        if video_windows and video_windows[0].movie:
            initial_dir = os.path.dirname(video_windows[0].movie)
        
        for window in video_windows:
            # Prompt user to select h5 file for this camera
            movie_name = window.movie.split('/')[-1] if window.movie else f"Camera {window.actual_camera_number}"
            
            filename, _ = QtWidgets.QFileDialog.getOpenFileName(
                self, 
                f"Select DeepLabCut h5 file for {movie_name} (Camera {window.actual_camera_number})",
                dir=initial_dir,
                filter="HDF5 files (*.h5 *.hdf5)"
            )
            
            if not filename:
                # User cancelled, don't continue
                QtWidgets.QMessageBox.information(None,
                    "Cancelled",
                    "DeepLabCut data loading cancelled."
                )
                return
            
            h5_file_paths.append(filename)
        
        # All files selected, now call load_dlc function
        try:
            # Store H5 file paths globally for re-filtering when threshold changes
            dlc_h5_file_paths = h5_file_paths.copy()
            
            # Use the likelihood threshold from the input widget
            likelihood_threshold = self.dlc_likelihood_input.value()
            load_dlc(h5_file_paths, like=likelihood_threshold)
            
            # Update the track list in the GUI after successful loading
            global track_list_global, current_track_global
            self.track_list = track_list_global.copy()
            
            # Clear and repopulate the tracks combobox
            self.tracks.clear()
            self.tracks.addItems(self.track_list)
            
            # Set the current track to the first one
            if self.track_list:
                current_track_global = self.track_list[0]
                self.tracks.setCurrentText(current_track_global)
            
            # Clear existing track data and update all video windows with the new track data
            for window in pyglet.app.windows:
                if isinstance(window, ClickerWindow):
                    # Clear existing track data first
                    window.points.clear()
                    # Now update with new DLC tracks
                    window.update_tracks()  # Create track keys
                    window.load_points()    # Load actual data from load_data_global
            
            QtWidgets.QMessageBox.information(None,
                "Success",
                f"Successfully loaded DeepLabCut data from {len(h5_file_paths)} file(s).\n"
                f"Track list updated with {len(self.track_list)} body parts."
            )
        except Exception as e:
            QtWidgets.QMessageBox.warning(None,
                "Error",
                f"Failed to load DeepLabCut data: {str(e)}"
            )

    def save_labeled_videos(self):
        """Generate labeled videos by overlaying xypts marker data on the loaded videos."""
        import importlib.util
        import argus_gui as _ag_pkg

        # Locate label_video_from_xypts.py relative to the argus_gui package root
        try:
            _pkg_file = os.path.abspath(_ag_pkg.__file__)
            _repo_root = os.path.dirname(os.path.dirname(_pkg_file))
            _label_script = os.path.join(_repo_root, 'utils', 'label_video_from_xypts.py')
            if not os.path.exists(_label_script):
                raise FileNotFoundError(f"Script not found:\n{_label_script}")
            spec = importlib.util.spec_from_file_location('label_video_from_xypts', _label_script)
            mod = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(mod)
            label_video_fn = mod.label_video
        except Exception as e:
            QtWidgets.QMessageBox.warning(self, "Error",
                f"Could not load label_video_from_xypts.py:\n{str(e)}")
            return

        # Check that xypts have been saved
        global global_filename
        if not global_filename:
            QtWidgets.QMessageBox.warning(self, "Save Points First",
                "Points have not been saved yet.\n"
                "Please save your points (S key or Ctrl+S) before generating labeled videos.")
            return

        csv_path = global_filename + '-xypts.csv'
        if not os.path.exists(csv_path):
            QtWidgets.QMessageBox.warning(self, "Error",
                f"xypts CSV not found:\n{csv_path}\n\nPlease save your points first.")
            return

        # Get all video windows
        video_windows = [w for w in pyglet.app.windows if isinstance(w, ClickerWindow)]
        video_windows.sort(key=lambda w: w.actual_camera_number)
        if not video_windows:
            QtWidgets.QMessageBox.warning(self, "Error",
                "No video windows are currently open.")
            return

        # Ask for output directory, defaulting to the directory of the xypts CSV
        default_dir = os.path.dirname(os.path.abspath(global_filename))
        output_dir = QtWidgets.QFileDialog.getExistingDirectory(
            self, "Select output directory for labeled videos", default_dir)
        if not output_dir:
            return

        # Use the current marker radius setting
        marker_radius = radius

        # Process each video with a progress dialog
        progress = QtWidgets.QProgressDialog(
            "Generating labeled videos...", "Cancel", 0, len(video_windows), self)
        progress.setWindowModality(QtCore.Qt.WindowModal)
        progress.setMinimumDuration(0)
        progress.show()
        QtWidgets.QApplication.processEvents()

        errors = []
        for i, window in enumerate(video_windows):
            if progress.wasCanceled():
                break
            cam_num = window.actual_camera_number
            video_path = window.movie
            video_stem = os.path.splitext(os.path.basename(video_path))[0]
            output_path = os.path.join(output_dir, f"{video_stem}_cam{cam_num}_labeled.mp4")
            progress.setLabelText(
                f"Processing camera {cam_num} ({i + 1}/{len(video_windows)})...")
            QtWidgets.QApplication.processEvents()
            try:
                label_video_fn(
                    video_path=video_path,
                    csv_path=csv_path,
                    camera_num=cam_num,
                    output_path=output_path,
                    marker_size=marker_radius,
                )
            except Exception as e:
                errors.append(f"Camera {cam_num}: {str(e)}")
            progress.setValue(i + 1)
            QtWidgets.QApplication.processEvents()

        progress.close()

        if errors:
            QtWidgets.QMessageBox.warning(self, "Errors",
                "Some videos could not be labeled:\n" + "\n".join(errors))
        else:
            n = len(video_windows)
            QtWidgets.QMessageBox.information(self, "Done",
                f"Successfully labeled {n} video(s).\nSaved to: {output_dir}")

class newTrackPopup(QtWidgets.QDialog):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setWindowTitle("Name the new track")
        layout = QtWidgets.QVBoxLayout(self)
        self.line_edit = QtWidgets.QLineEdit()
        layout.addWidget(self.line_edit)
        button = QtWidgets.QPushButton("Ok")
        button.clicked.connect(self.accept)
        layout.addWidget(button)

def draw_circle(coordinates, radius, color = (255, 255, 255, 255), batch = None):
    # coordinates should be passed in as a tupple of (x1, y1)
    x = coordinates[0]
    y = coordinates[1]
    return shapes.Circle(
                x, y, radius,
                color = color,
                batch = batch
    )
    
def draw_line(pt1, pt2, color=(255, 255, 255, 255), width = None, batch=None):
    global thickness
    if width == None:
        width = thickness
    # pt1 and pt2 are tuples or arrays like (x, y) for the two ends of the line
    (x1, y1) = pt1
    (x2, y2) = pt2
    
    # Pyglet 2.1+ removed the width parameter for Line
    # Create line without width parameter for compatibility
    # But there are other issues with window size that need to be fixed still - so install is forced to pyglet < 2.1
    try:
        # Try with width parameter (Pyglet 2.0.x)
        return shapes.Line(
            x1, y1, x2, y2,
            width = width,
            color = color,
            batch = batch
        )
    except TypeError:
        # Fallback without width parameter (Pyglet 2.1+)
        return shapes.Line(
            x1, y1, x2, y2,
            color = color,
            batch = batch
        )


